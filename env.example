# Copy to .env (or export these directly) for running Alembic / seed scripts
# from the command line, outside of Streamlit's secrets.toml mechanism.

# Supabase Postgres connection string. Use the "Connection pooling" URI
# (port 6543) from Supabase Project Settings -> Database -> Connection string.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[email protected]:6543/postgres

# Only needed if you run scripts that call the Supabase client directly
# (the Streamlit app reads these from .streamlit/secrets.toml instead).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY
